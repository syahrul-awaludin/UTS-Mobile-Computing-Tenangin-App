const swaggerJsdoc = require('swagger-jsdoc');
const swaggerUi = require('swagger-ui-express');
const config = require('../config');

const options = {
  definition: {
    openapi: '3.0.3',
    info: {
      title: 'Tenangin API',
      version: '1.0.0',
      description: 'REST API untuk fitur Community di Tenangin App.',
    },
    servers: [
      { url: 'https://tenangin.syahrulawaludin.my.id/api/v1', description: 'Production Server' },
      { url: `http://localhost:${config.port || 4005}/api/v1`, description: 'Local Dev' }
    ],
    components: {
      schemas: {
        User: {
          type: 'object',
          properties: {
            id: { type: 'string', example: 'uuid-1234' },
            name: { type: 'string', example: 'Budi Santoso' },
            email: { type: 'string', example: 'budi@example.com' },
            avatarUrl: { type: 'string', example: 'https://example.com/avatar.jpg' },
            createdAt: { type: 'string', format: 'date-time' },
          },
        },
        Post: {
          type: 'object',
          properties: {
            id: { type: 'string', example: 'post-123' },
            subject: { type: 'string', example: 'Merasa cemas hari ini' },
            content: { type: 'string', example: 'Saya merasa sangat cemas karena pekerjaan menumpuk.' },
            mood: { type: 'string', example: 'anxious' },
            authorId: { type: 'string', example: 'uuid-1234' },
            createdAt: { type: 'string', format: 'date-time' },
            stats: {
              type: 'object',
              properties: {
                likeCount: { type: 'integer', example: 5 },
                commentCount: { type: 'integer', example: 2 },
              }
            },
            isLikedByMe: { type: 'boolean', example: true },
          },
        },
        Comment: {
          type: 'object',
          properties: {
            id: { type: 'string', example: 'comment-123' },
            text: { type: 'string', example: 'Semangat ya!' },
            postId: { type: 'string', example: 'post-123' },
            authorId: { type: 'string', example: 'uuid-1234' },
            parentId: { type: 'string', nullable: true, example: null },
            createdAt: { type: 'string', format: 'date-time' },
            author: {
              type: 'object',
              properties: {
                id: { type: 'string' },
                name: { type: 'string' },
                email: { type: 'string' },
              }
            },
            replies: {
              type: 'array',
              items: {
                type: 'object',
                description: 'Objek komentar yang sama (1 tingkat)',
              }
            }
          },
        },
        ErrorResponse: {
          type: 'object',
          properties: {
            error: {
              type: 'object',
              properties: {
                code: { type: 'string', example: 'VALIDATION_ERROR' },
                message: { type: 'string', example: 'Data yang dikirim tidak valid.' },
                details: {
                  type: 'array',
                  items: {
                    type: 'object',
                    properties: {
                      field: { type: 'string' },
                      message: { type: 'string' },
                    },
                  },
                },
              },
            },
          },
        },
      },
      securitySchemes: {
        bearerAuth: {
          type: 'http',
          scheme: 'bearer',
          bearerFormat: 'JWT',
        },
      },
    },
    security: [{ bearerAuth: [] }],
  },
  apis: ['./src/routes/*.js'],
};

const swaggerSpec = swaggerJsdoc(options);

const setupSwagger = (app) => {
  app.use('/api/docs', swaggerUi.serve, swaggerUi.setup(swaggerSpec, {
    customSiteTitle: `${config.appName || 'Tenangin'} - API Docs`,
  }));

  app.get('/api/docs.json', (req, res) => {
    res.setHeader('Content-Type', 'application/json');
    res.send(swaggerSpec);
  });

  console.log(` Docs        : http://localhost:${config.port || 4005}/api/docs`);
};

module.exports = setupSwagger;
